generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trip {
  id           String   @id @default(cuid())
  title        String
  description  String?
  password     String?
  startDate    DateTime?
  endDate      DateTime?
  
  // Strict Relational Data Ownership
  ownerId      String
  owner        User     @relation("TripOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  // M:N relationship for invited participants
  participants User[]   @relation("TripParticipants")
  inviteToken  String   @unique @default(cuid())
  bucketListUrl String?  // Google Maps list URL for the "Bucket List" catalog

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  days     DayPlan[]
  expenses Expense[]
}

enum Role {
  USER
  ADMIN
}

enum PlanTier {
  FREE
  SINGLE_TRIP
  MONTHLY
  YEARLY
}

model Coupon {
  id           String   @id @default(cuid())
  code         String   @unique
  planGranted  PlanTier
  usesLeft     Int      @default(1)
  startsAt     DateTime?  // Coupon only valid after this date
  expiresAt    DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  
  // Who created it
  createdBy    String
  admin        User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?  // Optional for OAuth users
  name      String?
  
  // Authentication & Authorization
  role      Role     @default(USER)
  googleId  String?  @unique
  appleId   String?  @unique
  
  // Subscriptions
  plan      PlanTier @default(FREE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  ownedTrips    Trip[]     @relation("TripOwner")
  joinedTrips   Trip[]     @relation("TripParticipants")
  adminLogs     AdminLog[]
  issuedCoupons Coupon[]
  aiUsages      AiUsage[]
}

model AiUsage {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tripId           String?
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCost    Float
  createdAt        DateTime @default(now())
}

model AdminLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model DayPlan {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  dayNumber Int
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations Location[]
}

model Location {
  id          String   @id @default(cuid())
  dayPlanId   String
  dayPlan     DayPlan  @relation(fields: [dayPlanId], references: [id], onDelete: Cascade)
  name        String
  description String?
  timeSlot    String?  // e.g. "09:00 - 11:00"
  lat         Float
  lng         Float
  completed   Boolean  @default(false)
  tag         String?
  mapsUrl     String?
  notes       String?  // General notes/links (reels, booking, tips, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  amount      Float
  description String
  paidBy      String
  date        DateTime
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
